class Solution {
  public:
    long long int commDiv(long long int a, long long int b) {
        // code here
        long long int cnt = 0;
        long long int i = 1;
        
        while (i <= a and i <= b) {
            if (a % i == 0 and b % i == 0)
                cnt++;
            i++;
        }
        
        return cnt;
    }
};
